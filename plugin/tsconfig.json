{
  "compilerOptions": {
    "strict": true,
    "target": "ES2017",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "build",
    "rootDir": "src",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"],
  "exclude": ["build"]
}
